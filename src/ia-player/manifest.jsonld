{
  "@context": {
    "@version": 1.1,
    "ui": "http://www.w3.org/ns/ui#",
    "dct": "http://purl.org/dc/terms/",
    "schema": "http://schema.org/",
    "Component": "ui:Component",
    "Menu": "ui:Menu",
    "label": "ui:label",
    "name": "ui:name",
    "publisher": "dct:publisher",
    "subject": "dct:subject",
    "hasPart": {
      "@id": "dct:hasPart",
      "@type": "@id"
    },
    "requires": {
      "@id": "dct:requires",
      "@type": "@id"
    },
    "shape": {
      "@id": "dct:conformsTo",
      "@type": "@id"
    },
    "help": {
      "@id": "schema:softwareHelp",
      "@type": "@id"
    },
    "parts": {
      "@id": "ui:parts",
      "@container": "@list",
      "@type": "@id"
    },
    "icon": "ui:icon"
  },
  "@id": "",
  "@type": "Component",
  "label": "Internet Archive player",
  "name": "ia-player",
  "publisher": "Jeff Zucker",
  "hasPart": [
    "./ia3.js",
    "./ia-ui.js",
    "./ia-rdf.js",
    "./assets/ia-player-shell.html",
    "./assets/ia.css"
  ],
  "requires": [
    "../../libraries/internet_archive_music/index.ttl",
    "../../libraries/internet_archive_movies/index.ttl",
    "../../libraries/internet_archive_spoken_word/index.ttl"
  ],
  "help": "./assets/ia-help.html",
  "shape": "../../shapes/music.shacl",
  "subject": "Media",
  "icon": "🎵"
}
